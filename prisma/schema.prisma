generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// USUÁRIOS (autenticação)
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?   // 🆕 opcional (usuários Google não têm senha)
  emailVerified DateTime? // 🆕 NextAuth precisa
  image         String?   // 🆕 foto do Google
  role          String    @default("visualizador") // 🔄 admin | operador | visualizador
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 🆕 Relações do NextAuth (Google OAuth)
  accounts Account[]
  sessions Session[]

  // Relações com DailyApproval (aproveitamentos diários)
  dailyApprovalsCreated DailyApproval[] @relation("DailyApprovalCreatedBy")
  dailyApprovalsUpdated DailyApproval[] @relation("DailyApprovalUpdatedBy")
}

// ==========================================
// 🆕 NEXTAUTH: Account (provedores OAuth)
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ==========================================
// 🆕 NEXTAUTH: Session
// ==========================================
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 🆕 NEXTAUTH: VerificationToken
// ==========================================
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// PRODUTOS (o que é doado/distribuído)
// ==========================================
model Product {
  id        String   @id @default(cuid())
  name      String
  category  String
  unit      String
  minStock  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donationItems     DonationItem[]
  distributionItems DistributionItem[]
  harvestItems      HarvestItem[]
}

// ==========================================
// DOADORES (quem doa)
// ==========================================
model Donor {
  id        String   @id @default(cuid())
  name      String
  type      String
  category  String
  contact   String?
  phone     String?
  email     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donations Donation[]
}

// ==========================================
// INSTITUIÇÕES BENEFICIÁRIAS (quem recebe)
// ==========================================
model Beneficiary {
  id        String   @id @default(cuid())
  name      String
  type      String
  address   String?
  phone     String?
  contact   String?
  status    String   @default("ativo")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distributions Distribution[]
}

// ==========================================
// FUNCIONÁRIOS (quem faz a coleta/entrega)
// ==========================================
model Employee {
  id        String   @id @default(cuid())
  name      String
  role      String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Doações - até 3 funcionários por coleta
  donationsAsEmployee1 Donation[] @relation("DonationEmployee1")
  donationsAsEmployee2 Donation[] @relation("DonationEmployee2")
  donationsAsEmployee3 Donation[] @relation("DonationEmployee3")

  // Distribuições - até 3 funcionários por entrega
  distributionsAsEmployee1 Distribution[] @relation("DistributionEmployee1")
  distributionsAsEmployee2 Distribution[] @relation("DistributionEmployee2")
  distributionsAsEmployee3 Distribution[] @relation("DistributionEmployee3")

  // Colheitas - até 3 funcionários por colheita
  harvestsAsEmployee1 SolidarityHarvest[] @relation("HarvestEmployee1")
  harvestsAsEmployee2 SolidarityHarvest[] @relation("HarvestEmployee2")
  harvestsAsEmployee3 SolidarityHarvest[] @relation("HarvestEmployee3")
}

// ==========================================
// DOAÇÃO (entrada de alimentos)
// ==========================================
model Donation {
  id         String   @id @default(cuid())
  donorId    String
  date       DateTime @default(now())
  origin     String   @default("coleta")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Funcionários da coleta (1 obrigatório, 2 opcionais)
  employeeId   String?
  employee     Employee? @relation("DonationEmployee1", fields: [employeeId], references: [id])

  employee2Id  String?
  employee2    Employee? @relation("DonationEmployee2", fields: [employee2Id], references: [id])

  employee3Id  String?
  employee3    Employee? @relation("DonationEmployee3", fields: [employee3Id], references: [id])

  donor Donor          @relation(fields: [donorId], references: [id])
  items DonationItem[]
}

// ==========================================
// ITENS DA DOAÇÃO
// ==========================================
model DonationItem {
  id         String  @id @default(cuid())
  donationId String
  productId  String
  quantity   Float
  boxes      Int?
  weighed    Boolean @default(false)

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
}

// ==========================================
// DISTRIBUIÇÃO (saída de alimentos)
// ==========================================
model Distribution {
  id            String   @id @default(cuid())
  beneficiaryId String
  date          DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Funcionários da entrega (1 obrigatório, 2 opcionais)
  employeeId   String?
  employee     Employee? @relation("DistributionEmployee1", fields: [employeeId], references: [id])

  employee2Id  String?
  employee2    Employee? @relation("DistributionEmployee2", fields: [employee2Id], references: [id])

  employee3Id  String?
  employee3    Employee? @relation("DistributionEmployee3", fields: [employee3Id], references: [id])

  beneficiary Beneficiary        @relation(fields: [beneficiaryId], references: [id])
  items       DistributionItem[]
}

// ==========================================
// ITENS DA DISTRIBUIÇÃO
// ==========================================
model DistributionItem {
  id             String @id @default(cuid())
  distributionId String
  productId      String
  quantity       Float
  boxes          Int?

  distribution Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
}

// ==========================================
// PRODUTORES RURAIS (Colheita Solidária)
// ==========================================
model Producer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  property  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  harvests SolidarityHarvest[]
}

// ==========================================
// COLHEITA SOLIDÁRIA (evento de colheita)
// ==========================================
model SolidarityHarvest {
  id             String   @id @default(cuid())
  producerId     String
  date           DateTime @default(now())
  status         String   @default("agendada")
  notes          String?
  indemnityValue Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Funcionários da colheita (1 obrigatório, 2 opcionais)
  employeeId  String?
  employee    Employee? @relation("HarvestEmployee1", fields: [employeeId], references: [id])

  employee2Id String?
  employee2   Employee? @relation("HarvestEmployee2", fields: [employee2Id], references: [id])

  employee3Id String?
  employee3   Employee? @relation("HarvestEmployee3", fields: [employee3Id], references: [id])

  producer Producer      @relation(fields: [producerId], references: [id])
  items    HarvestItem[]
}

// ==========================================
// ITENS DA COLHEITA
// ==========================================
model HarvestItem {
  id        String @id @default(cuid())
  harvestId String
  productId String
  quantity  Float
  boxes     Int?

  harvest SolidarityHarvest @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  product Product           @relation(fields: [productId], references: [id])
}

// ==========================================
// APROVEITAMENTO DIÁRIO (2ª triagem)
// Registra quanto das doações foi efetivamente
// aproveitado após a triagem do dia
// ==========================================
model DailyApproval {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  approvedQty Float    // peso líquido aproveitado em kg
  notes       String?

  createdById String
  createdBy   User     @relation("DailyApprovalCreatedBy", fields: [createdById], references: [id])

  updatedById String?
  updatedBy   User?    @relation("DailyApprovalUpdatedBy", fields: [updatedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@map("daily_approvals")
}
