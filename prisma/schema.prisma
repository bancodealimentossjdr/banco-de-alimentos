generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// USUÁRIOS (autenticação)
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("visualizador")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  dailyApprovalsCreated DailyApproval[] @relation("DailyApprovalCreatedBy")
  dailyApprovalsUpdated DailyApproval[] @relation("DailyApprovalUpdatedBy")

  // 🆕 ONDA 16.2 — Marcos de Estoque
  stockMarkersCreated StockMarker[] @relation("StockMarkerCreatedBy")

  // 🆕 ONDA 16.6a — Comprovantes de entrega finalizados (auditoria)
  receiptsFinalized DeliveryReceipt[] @relation("ReceiptFinalizedBy")
}

// ==========================================
// NEXTAUTH
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// PRODUTOS
// ==========================================
model Product {
  id        String   @id @default(cuid())
  name      String
  category  String
  unit      String
  minStock  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donationItems     DonationItem[]
  distributionItems DistributionItem[]
  harvestItems      HarvestItem[]
}

// ==========================================
// DOADORES
// ==========================================
model Donor {
  id        String   @id @default(cuid())
  name      String
  type      String
  category  String
  contact   String?
  phone     String?
  email     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donations Donation[]
}

// ==========================================
// BENEFICIÁRIOS
// ==========================================
model Beneficiary {
  id        String   @id @default(cuid())
  name      String
  type      String
  address   String?
  phone     String?
  contact   String?
  status    String   @default("ativo")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distributions Distribution[]
}

// ==========================================
// FUNCIONÁRIOS
// ==========================================
model Employee {
  id        String   @id @default(cuid())
  name      String
  role      String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donationsAsEmployee1 Donation[] @relation("DonationEmployee1")
  donationsAsEmployee2 Donation[] @relation("DonationEmployee2")
  donationsAsEmployee3 Donation[] @relation("DonationEmployee3")

  distributionsAsEmployee1 Distribution[] @relation("DistributionEmployee1")
  distributionsAsEmployee2 Distribution[] @relation("DistributionEmployee2")
  distributionsAsEmployee3 Distribution[] @relation("DistributionEmployee3")

  harvestsAsEmployee1 SolidarityHarvest[] @relation("HarvestEmployee1")
  harvestsAsEmployee2 SolidarityHarvest[] @relation("HarvestEmployee2")
  harvestsAsEmployee3 SolidarityHarvest[] @relation("HarvestEmployee3")
}

// ==========================================
// DOAÇÃO
// ==========================================
model Donation {
  id         String   @id @default(cuid())
  donorId    String
  date       DateTime @default(now())
  origin     String   @default("coleta")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employeeId   String?
  employee     Employee? @relation("DonationEmployee1", fields: [employeeId], references: [id])

  employee2Id  String?
  employee2    Employee? @relation("DonationEmployee2", fields: [employee2Id], references: [id])

  employee3Id  String?
  employee3    Employee? @relation("DonationEmployee3", fields: [employee3Id], references: [id])

  donor Donor          @relation(fields: [donorId], references: [id])
  items DonationItem[]
}

model DonationItem {
  id         String  @id @default(cuid())
  donationId String
  productId  String
  quantity   Float
  boxes      Int?
  weighed    Boolean @default(false)

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
}

// ==========================================
// DISTRIBUIÇÃO
// ==========================================
model Distribution {
  id            String   @id @default(cuid())
  beneficiaryId String
  date          DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 🆕 ONDA 16.6a — Status + flag de legado
  status        DistributionStatus @default(PENDENTE)
  legacy        Boolean            @default(false)

  employeeId   String?
  employee     Employee? @relation("DistributionEmployee1", fields: [employeeId], references: [id])

  employee2Id  String?
  employee2    Employee? @relation("DistributionEmployee2", fields: [employee2Id], references: [id])

  employee3Id  String?
  employee3    Employee? @relation("DistributionEmployee3", fields: [employee3Id], references: [id])

  beneficiary Beneficiary        @relation(fields: [beneficiaryId], references: [id])
  items       DistributionItem[]

  // 🆕 ONDA 16.6a — Comprovante de entrega (1:1)
  receipt     DeliveryReceipt?

  @@index([status])
}

model DistributionItem {
  id             String @id @default(cuid())
  distributionId String
  productId      String
  quantity       Float
  boxes          Int?

  distribution Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
}

// ==========================================
// PRODUTORES RURAIS
// ==========================================
model Producer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  property  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  harvests SolidarityHarvest[]
}

// ==========================================
// COLHEITA SOLIDÁRIA
// status: "agendada" | "realizada" | "cancelada"
// ==========================================
model SolidarityHarvest {
  id             String   @id @default(cuid())
  producerId     String
  date           DateTime @default(now())
  status         String   @default("agendada")
  notes          String?
  indemnityValue Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employeeId  String?
  employee    Employee? @relation("HarvestEmployee1", fields: [employeeId], references: [id])

  employee2Id String?
  employee2   Employee? @relation("HarvestEmployee2", fields: [employee2Id], references: [id])

  employee3Id String?
  employee3   Employee? @relation("HarvestEmployee3", fields: [employee3Id], references: [id])

  producer Producer      @relation(fields: [producerId], references: [id])
  items    HarvestItem[]
}

model HarvestItem {
  id        String @id @default(cuid())
  harvestId String
  productId String
  quantity  Float
  boxes     Int?

  harvest SolidarityHarvest @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  product Product           @relation(fields: [productId], references: [id])
}

// ==========================================
// APROVEITAMENTO DIÁRIO (triagem das doações)
// ==========================================
model DailyApproval {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  approvedQty Float
  notes       String?

  createdById String
  createdBy   User     @relation("DailyApprovalCreatedBy", fields: [createdById], references: [id])

  updatedById String?
  updatedBy   User?    @relation("DailyApprovalUpdatedBy", fields: [updatedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@map("daily_approvals")
}

// ==========================================
// 🆕 ONDA 16.2 — MARCOS DE ESTOQUE
// ==========================================
enum StockMarkerType {
  ZERO
  ADJUSTMENT
}

model StockMarker {
  id          String          @id @default(cuid())
  type        StockMarkerType
  date        DateTime        @unique @db.Date
  quantityKg  Float
  note        String?

  createdById String
  createdBy   User            @relation("StockMarkerCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([date])
  @@index([type])
  @@map("stock_markers")
}

// ==========================================
// 🆕 ONDA 16.6a — STATUS DE DISTRIBUIÇÃO
// PENDENTE  — criada, aguardando finalização (entrega + assinatura)
// ENTREGUE  — finalizada com comprovante (ou legado migrado)
// (CANCELADA fora de escopo nesta onda — decisão 09/06/2026)
// ==========================================
enum DistributionStatus {
  PENDENTE
  ENTREGUE
}

// ==========================================
// 🆕 ONDA 16.6a — COMPROVANTE DE ENTREGA
// Comprovante = assinatura digital do recebedor.
// Relação 1:1 com Distribution.
//
// Regras:
//   - Criado ao finalizar a distribuição (status → ENTREGUE)
//   - signatureSvg: assinatura vetorizada, SEM storage externo
//   - finalizedBy: operador/admin que finalizou (auditoria)
//   - legacy → não gera comprovante (só muda status na Distribution)
//   - Edição: apenas Admin, trava temporal do mesmo dia (validada na API)
//   - VISIBILIDADE: oculto para role "visualizador" (filtrado na serialização)
// ==========================================
model DeliveryReceipt {
  id             String       @id @default(cuid())
  distributionId String       @unique
  distribution   Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)

  recipientName  String
  signatureData  String       @db.Text // PNG base64 (data URL) gerado pelo react-signature-canvas
  notes          String?      @db.Text

  finalizedById  String
  finalizedBy    User         @relation("ReceiptFinalizedBy", fields: [finalizedById], references: [id]) // 🔧 nome da relação adicionado
  finalizedAt    DateTime     @default(now())

  @@map("delivery_receipts")
}
